#Checks whether a character is:

Alphabet
Digit
Special character
Uppercase / Lowercase
ch = input("Enter a character: ")

if ch.isalpha():
    print("Alphabet")

    if ch.isupper():
        print("Uppercase Letter")
    else:
        print("Lowercase Letter")

elif ch.isdigit():
    print("Digit")

else:
    print("Special Character")
