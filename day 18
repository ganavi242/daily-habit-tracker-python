#odd numbers in range
start = int(input("Enter start: "))
end = int(input("Enter end: "))

print("Odd numbers are:")

for i in range(start, end + 1):
    if i % 2 != 0:
        print(i, end=" ")
#sum of even numbers
start = int(input("Enter start: "))
end = int(input("Enter end: "))

sum_even = 0

for i in range(start, end + 1):
    if i % 2 == 0:
        sum_even += i

print("Sum of even numbers =", sum_even)
