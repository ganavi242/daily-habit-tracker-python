#factorial
#include <stdio.h>

int main() {
    int n, i;
    long long factorial = 1;

    printf("Enter a number: ");
    scanf("%d", &n);

    if(n < 0) {
        printf("Factorial not defined for negative numbers.");
    } else {
        for(i = 1; i <= n; i++) {
            factorial *= i;
        }
        printf("Factorial of %d = %lld", n, factorial);
    }

    return 0;
}
#countdown timer
#include <stdio.h>
#include <unistd.h> // for sleep()

int main() {
    int n;

    printf("Enter starting number: ");
    scanf("%d", &n);

    while(n > 0) {
        printf("%d\n", n);
        sleep(1); // waits for 1 second
        n--;
    }

    printf("Time's up!\n");

    return 0;
}
