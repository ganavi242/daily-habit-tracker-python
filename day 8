#vowel or consonant checker
  print("=== Vowel or Consonant Checker ===")

ch = input("Enter a single alphabet: ")

if len(ch) == 1 and ch.isalpha():
    ch = ch.lower()

    if ch in ['a', 'e', 'i', 'o', 'u']:
        print(ch, "is a Vowel")
    else:
        print(ch, "is a Consonant")
else:
    print("Please enter only one alphabet.")
#username validation
  print(" Username Validation ")

username = input("Enter a username: ")

if len(username) < 5:
    print("Invalid Username: Must be at least 5 characters long.")
elif not username[0].isalpha():
    print("Invalid Username: Must start with a letter.")
elif not username.isalnum():
    print("Invalid Username: Only letters and numbers are allowed.")
else:
    print("Valid Username")
